{
  "name": "Westerfield",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers-contrib/features/angular-cli:2": {},
    "ghcr.io/devcontainers-contrib/features/nx-npm": {}
  },
  "postAttachCommand": "nvm use lts/* && exit",
  "customizations": {
    "vscode": {
      "extensions": [
        "Angular.ng-template",
        "blinkshellinc.blink-fs",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "firsttris.vscode-jest-runner",
        "GitHub.remotehub",
        "nrwl.angular-console",
        "rbalet.vscode-sorting-attrs",
        "yzhang.markdown-all-in-one",
        "ZainChen.json",
        "IanWesterfield.dark-plus-dank"
      ]
    }
  }
}
